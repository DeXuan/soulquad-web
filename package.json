{
  "name": "soulquad-web",
  "version": "1.0.0",
  "description": "SoulQuad - 灵魂象限智能择偶匹配系统",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "package": "npm run build && node scripts/create-dist.js",
    "package:exe": "npm run build && npx ncc build server/index.js -o dist-server && npx pkg dist-server/index.js -t node18-win-x64 --output release/soulquad.exe && node scripts/create-exe-dist.js",
    "electron:dev": "cross-env NODE_ENV=development electron electron/main.js",
    "electron:build": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux"
  },
  "bin": {
    "soulquad": "./server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sql.js": "^1.14.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vercel/ncc": "^0.38.4",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "pkg": "^5.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  }
}
