# SoulQuad 环境变量配置示例
# 复制为 .env 文件并修改对应值

# 运行环境
NODE_ENV=production

# 服务器端口
PORT=3000

# PostgreSQL 数据库配置
PG_HOST=your-pg-host.com
PG_PORT=5432
PG_DATABASE=soulquad
PG_USER=postgres
PG_PASSWORD=your-password

# JWT 密钥 (生产环境请使用复杂的随机字符串)
TOKEN_SECRET=your-super-secret-token-key-change-in-production

# CORS 允许的域名 (多个用逗号分隔)
CORS_ORIGIN=http://localhost:5173,https://your-domain.com

# Anthropic API Key (可选，用于AI灵魂描述)
ANTHROPIC_API_KEY=